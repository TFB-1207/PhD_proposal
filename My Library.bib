  title = {Survival of Environmental {{{\textsc{DNA}}}} in Sediments: {{Mineralogic}} Control on {{{\textsc{DNA}}}} Taphonomy},
  shorttitle = {Survival of Environmental},
  author = {Freeman, C. L. and Dieudonn{\'e}, L. and Agbaje, O. B. A. and {\v Z}ure, M. and Sanz, J. Q. and Collins, M. and Sand, K. K.},
  year = 2023,
